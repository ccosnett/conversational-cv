# Hume credentials — get these from https://platform.hume.ai/settings/keys
HUME_API_KEY=your_api_key_here
HUME_SECRET_KEY=your_secret_key_here

# Optional. If set, Hume will use your saved conversational-CV config and voice.
# If left blank, the app still works by sending a grounded session prompt at runtime.
HUME_CONFIG_ID=
